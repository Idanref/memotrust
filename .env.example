# Mixpanel read-only verifier credentials.
# Copy this file to `.env` and fill in your values. `.env` is gitignored —
# never commit a real secret. The service account should be least-privilege
# (Consumer if it can still run queries, otherwise Analyst); the verifier only
# ever reads.
MIXPANEL_PROJECT_ID=your-project-id
MIXPANEL_SA_USER=your-service-account.mp-service-account
MIXPANEL_SA_SECRET=paste-your-read-only-secret-here
